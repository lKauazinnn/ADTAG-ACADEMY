# Database - Escolha uma das opções abaixo:

# Opção 1: Supabase (Recomendado)
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# Opção 2: PostgreSQL Local
# DATABASE_URL="postgresql://postgres:password@localhost:5432/video_platform?schema=public"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/video_platform?schema=public"

# JWT - MUDE ISSO para uma string aleatória e segura!
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Server
PORT=3333
NODE_ENV=development

# Groq - Lumi Assistente Virtual (obtenha em console.groq.com)
GROQ_API_KEY="sua_chave_groq_aqui"

# Frontend URL (usada no link de redefinição)
FRONTEND_URL="http://localhost:5173"

# SMTP (obrigatório para enviar email de redefinição)
SMTP_HOST="smtp.seuprovedor.com"
SMTP_PORT=587
SMTP_USER="seu_email@dominio.com"
SMTP_PASS="sua_senha_ou_app_password"
SMTP_FROM="Plataforma de Vídeos <no-reply@dominio.com>"
